{
  "name": "telegram-mcp",
  "version": "0.1.0",
  "description": "Telegram bot + MCP server for Claude Code",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:door1": "tsx src/door1.ts",
    "start": "node dist/index.js",
    "start:door1": "node dist/door1.js",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:unit": "node --import tsx --test tests/sdk-runner.test.ts",
    "test:integration": "node --import tsx --test tests/sdk-integration.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.145",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.8.2",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "grammy": "^1.35.0",
    "nodejs-whisper": "^0.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
