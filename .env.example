# ── Core ────────────────────────────────────────────────────────────────────
# Telegram bot token from @BotFather (required).
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Comma-separated Telegram user IDs auto-seeded as `allowed` on startup
# (multi-admin). Empty = no auto-seed; access must be granted via /start +
# manual /approve. Legacy single-admin fallback: TELEGRAM_USER_ID.
TELEGRAM_ADMIN_USER_IDS=
# Comma-separated usernames parallel to the IDs (display only).
TELEGRAM_ADMIN_USERNAMES=

# HTTP port for the MCP SSE endpoint + console. Default 3848.
#PORT=3848

# SQLite database location. Default: ./messages.db in the working directory.
# Set an absolute path on production hosts so the DB survives deploys/cwd changes.
#TELEGRAM_MCP_DB_PATH=/var/lib/telegram-mcp/messages.db

# Where to write voice/video temp files. Default /tmp/telegram-mcp.
#TELEGRAM_MCP_MEDIA_DIR=/tmp/telegram-mcp

# ── Transcription (voice / video / URLs) ────────────────────────────────────
# Backend is chosen automatically: OPENAI_API_KEY set → OpenAI cloud;
# else WHISPER_SERVER_URL set → local whisper-server; else whisper-cli
# (nodejs-whisper) spawned per call.
#OPENAI_API_KEY=
#OPENAI_API_BASE=https://api.openai.com/v1
#OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
# Local whisper model: tiny | small | medium | large. Default medium.
#WHISPER_MODEL=medium
# Optional resident whisper-server /inference endpoint (skips per-call model load).
#WHISPER_SERVER_URL=http://localhost:9000

# ── Group engagement ────────────────────────────────────────────────────────
# Simple override: comma-separated group chat IDs where the bot notifies the
# agent on EVERY message (bypassing the mention/reply/slash policy). Channels
# are still excluded. Use sparingly.
#TELEGRAM_ALWAYS_ENGAGE_GROUPS=

# ── Multi-agent coordination groups (optional) ──────────────────────────────
# Chats where several agent bots co-exist with BotFather Group Privacy OFF.
# Comma-separated chat IDs. Messages here go through the coordination routing
# protocol (group-routing.ts) so exactly one bot responds.
#TELEGRAM_ALWAYS_ENGAGE_CHAT_IDS=
# This host owns the human-no-mention default in coordination groups
# (primary=true, secondary/backup=false). The backup host defers and only takes
# over via the grace-window failover if the primary did not respond.
#TELEGRAM_GROUP_PRIMARY_HOST=false
# Backup-host failover grace window (ms). After a human message with no mention
# the backup waits this long; if it sees NO response from the primary bot it
# engages. 0 disables failover. Default 7000.
#TELEGRAM_BACKUP_GRACE_MS=7000

# ── Multi-user session autospawn (Phase 2, optional) ────────────────────────
# When enabled, the first private message from an ALLOWED user drops a spawn
# request file into MULTIUSER_REQUEST_DIR; an external supervisor (systemd
# .path unit or similar) picks it up and starts an isolated per-user session.
# Default OFF — single-operator installs keep their exact behavior.
#MULTIUSER_AUTOSPAWN=0
#MULTIUSER_REQUEST_DIR=/var/lib/telegram-mcp/spawn-requests

# ── Operator control commands (optional, owner-only) ────────────────────────
# /clear and /model are intercepted in private chat (admin IDs above) and
# injected NATIVELY into the operator's live tmux session via host-provided
# scripts. Each feature is OFF unless its script path is set.
#OPERATOR_CLEAR_INJECT_SCRIPT=/path/to/operator-clear-inject.sh
#OPERATOR_MODEL_INJECT_SCRIPT=/path/to/operator-model-inject.sh

# ── /login OAuth refresh flow (optional, admin-only) ────────────────────────
# Host-side pipe script that drives `claude /login` inside the operator tmux.
#CLAUDE_LOGIN_PIPE=/path/to/claude-login-pipe.sh
#LOGIN_OPERATOR_UNIT=agent-os-operator.service
#LOGIN_OPERATOR_TMUX=operator
#LOGIN_TMUX_TMPDIR=/home/agent-os/.tmux
# Explicit tmux socket path override (auto-detected when unset).
#LOGIN_OPERATOR_SOCKET=

# ── Emergency notify endpoint ───────────────────────────────────────────────
# Shared secret for POST /emergency (host watchdogs push alerts straight to the
# admin chat, bypassing the agent). Endpoint is disabled when unset.
#EMERGENCY_NOTIFY_TOKEN=

# ── Console Mini App (optional) ─────────────────────────────────────────────
# Public HTTPS URL of the console (Telegram Mini App requires HTTPS). The
# /console command + chat menu button are installed only when set.
#CONSOLE_URL=https://console.example.com
# Telegram user ID allowed into /console/api/* (owner gate).
#CONSOLE_OWNER_ID=
# Max accepted age of Telegram initData, seconds. Default 3600.
#CONSOLE_INITDATA_MAX_AGE=3600
# Dagu drill-in service-session TTL, seconds. Default 3600.
#CONSOLE_SVC_TTL=3600
# Komodo TG-login ticket TTL, seconds. Default 60.
#CONSOLE_KOMODO_TICKET_TTL=60

# Komodo (server management) integration for the console:
#KOMODO_HOST_LOCAL=http://localhost:9120
#KOMODO_API_KEY=
#KOMODO_API_SECRET=
# Basic-auth pair the Komodo gateway expects for the TG-login hand-off.
#KOMODO_GATEWAY_USER=
#KOMODO_GATEWAY_PASS=
# Public URL of the Komodo UI (console card link + TG-login target).
#KOMODO_PUBLIC_URL=https://komodo.example.com

# Dagu (routines engine) integration for the console:
#DAGU_HOST_LOCAL=http://localhost:8080
# Base path Dagu is served under behind the console proxy. Default /console/svc/dagu.
#DAGU_BASE_PATH=/console/svc/dagu
#DAGU_AUTH_BASIC_USERNAME=
#DAGU_AUTH_BASIC_PASSWORD=
# Public URL of the Dagu UI (console card link).
#DAGU_PUBLIC_URL=https://dagu.example.com

# claude-peers broker (agents list in the console):
#CLAUDE_PEERS_BASE_URL=http://localhost:7899
#CLAUDE_PEERS_HEALTH_URL=http://localhost:7899/health

# ── SDK runner (src/main.ts entry point) ────────────────────────────────────
# Watchdog: max silence from a session before it is considered stuck, ms.
#WATCHDOG_SILENCE_MS=60000
# Idle session teardown, ms. Default 1800000 (30 min).
#SESSION_IDLE_TIMEOUT_MS=1800000
# Per-session budget cap, USD. Default 5.
#MAX_BUDGET_USD=5
